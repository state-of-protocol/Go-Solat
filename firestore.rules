rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: announcements
    // Fields:
    //   - title: string (required, 1-100 chars)
    //   - content: string (optional, 0-1000 chars)
    //   - imageUrl: string (optional, URL)
    //   - videoUrl: string (optional, URL)
    //   - type: string (required, enum: ['image', 'video', 'text'])
    //   - duration: number (required, 1-3600)
    //   - active: bool (required)
    //   - createdAt: number (required)
    //
    // Collection: settings
    // Document: global
    // Fields:
    //   - masjidName: string (required)
    //   - zone: string (required)
    //   - sidebarText: string (optional)
    //   - sidebarImageUrl: string (optional)
    //   - facebookLiveUrl: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "remixuser10@gmail.com");
    }

    function isValidAnnouncement(data) {
      return data.keys().hasAll(['title', 'type', 'duration', 'active', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.type in ['image', 'video', 'text'] &&
             data.duration is number && data.duration >= 1 && data.duration <= 3600 &&
             data.active is bool &&
             data.createdAt is number;
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['masjidName', 'zone']) &&
             data.masjidName is string && data.masjidName.size() > 0 &&
             data.zone is string && data.zone.size() > 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /announcements/{announcementId} {
      allow read: if true; // Publicly readable for the signage display
      allow create, update: if isAdmin() && isValidAnnouncement(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/global {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }

    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
